	"styles": {
		"blocks": {
			"core/latest-posts": {
				"elements": {
					"link": {
						"typography": {
							"textDecoration": "none"
						}
					}
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--headings)",
					"fontSize": "1.25rem",
					"lineHeight": "1.4"
				}
			},
			"core/list": {
				"color": {
					"text": "var(--wp--preset--color--text-regular)"
				}
			},
			"core/navigation": {
				"spacing": {
					"blockGap": "2rem"
				}
			},
			"core/paragraph": {
				"spacing": {
					"margin": {
						"bottom": "2em"
					}
				}
			},
			"core/post-date": {
				"color": {
					"text": "var(--wp--preset--color--text-light)"
				},
				"elements": {
					"link": {
						"typography": {
							"textDecoration": "none"
						}
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"core/post-terms": {
				"elements": {
					"link": {
						"color": {
							"text": "var(--wp--preset--color--text-light)"
						},
						"typography": {
							"textDecoration": "none"
						}
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--tiny)",
					"textTransform": "uppercase"
				}
			},
			"core/post-title": {
				"elements": {
					"link": {
						"typography": {
							"textDecoration": "none"
						}
					}
				},
				"spacing": {
					"blockGap": "var(--wp--style--block-gap)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--headings)",
					"fontSize": "var(--wp--preset--font-size--medium)",
					"fontWeight": "normal",
					"lineHeight": "var(--wp--custom--typography--line-height--tiny)"
				}
			},
			"core/pullquote": {
				"border": {
					"width": "1px 0"
				}
			},
			"core/quote": {
				"border": {
					"width": "0 0 0 2px"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--headings)"
				}
			},
			"core/separator": {
				"border": {
					"bottom": {
						"width": "1px"
					},
					"width": "1px"
				},
				"color": {
					"text": "var(--wp--preset--color--stroke)"
				}
			},
			"core/site-tagline": {
				"spacing": {
					"margin": {
						"bottom": "0",
						"top": "0"
					}
				}
			},
			"core/site-title": {
				"elements": {
					"link": {
						"typography": {
							"textDecoration": "none"
						}
					}
				},
				"spacing": {
					"margin": {
						"bottom": "0",
						"top": "0"
					}
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--base)",
					"fontSize": "1.875rem",
					"fontWeight": "normal",
					"lineHeight": "1"
				}
			},
			"core/spacer": {
				"spacing": {
					"blockGap": "0px"
				}
			},
			"core/template-part": {
				"spacing": {
					"margin": {
						"block-start": "0px",
						"bottom": "0px",
						"top": "0px"
					}
				}
			}
		},
		"color": {
			"background": "var(--wp--preset--color--background)",
			"text": "var(--wp--preset--color--text-regular)"
		},
		"elements": {
			"button": {
				"border": {
					"radius": "0",
					"width": "1px"
				},
				"color": {
					"background": "var(--wp--preset--color--foreground)",
					"text": "var(--wp--preset--color--background)"
				},
				"spacing": {
					"padding": "var(--wp--custom--button-padding--medium)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--base)",
					"fontSize": "var(--wp--preset--font-size--base)",
					"fontWeight": "600",
					"lineHeight": "1"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--custom--typography--font-size--heading-1)",
					"fontWeight": "normal",
					"lineHeight": "var(--wp--custom--typography--line-height--tiny)"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--custom--typography--font-size--heading-2)",
					"fontWeight": "normal",
					"lineHeight": "var(--wp--custom--typography--line-height--small)"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--custom--typography--font-size--heading-3)",
					"fontWeight": "normal",
					"lineHeight": "var(--wp--custom--typography--line-height--tiny)"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var(--wp--custom--typography--font-size--heading-4)",
					"fontWeight": "normal",
					"lineHeight": "var(--wp--custom--typography--line-height--tiny)"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "var(--wp--custom--typography--font-size--heading-5)",
					"fontWeight": "normal",
					"lineHeight": "var(--wp--custom--typography--line-height--normal)",
					"textTransform": "uppercase"
				}
			},
			"h6": {
				"typography": {
					"fontSize": "var(--wp--custom--typography--font-size--heading-6)",
					"fontWeight": "normal",
					"lineHeight": "var(--wp--custom--typography--line-height--normal)",
					"textTransform": "uppercase"
				}
			},
			"heading": {
				"color": {
					"text": "var(--wp--preset--color--headings)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--headings)"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--headings)"
				}
			}
		},
		"spacing": {
			"blockGap": "1.5rem"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--base)",
			"fontSize": "var(--wp--preset--font-size--base)",
			"lineHeight": "var(--wp--custom--typography--line-height--normal)"
		}
	},
