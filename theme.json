					"name": "Background Light to White",
					"slug": "vertical-background-to-background-light"
				}
			],
			"palette": [
				{
					"color": "#000000",
					"name": "Foreground",
					"slug": "foreground"
				},
				{
					"color": "#ffffff",
					"name": "Background",
					"slug": "background"
				},
				{
					"color": "#fefefe",
					"name": "Light",
					"slug": "light"
				},
				{
					"color": "#010101",
					"name": "Dark",
					"slug": "dark"
				},
				{
					"color": "#020202",
					"name": "Headings",
					"slug": "headings"
				},
				{
					"color": "#606060",
					"name": "Text Regular",
					"slug": "text-regular"
				},
				{
					"color": "#767676",
					"name": "Text Light",
					"slug": "text-light"
				},
				{
					"color": "#D4D4D4",
					"name": "Text Lighter",
					"slug": "text-lighter"
				},
				{
					"color": "#F2F0EC",
					"name": "Background Light",
					"slug": "background-light"
				},
				{
					"color": "#000000",
					"name": "Primary",
					"slug": "primary"
				},
				{
					"color": "#F9F3F0",
					"name": "Secondary",
					"slug": "secondary"
				},
				{
					"color": "#F8F7F4",
					"name": "Tertiary",
					"slug": "tertiary"
				},
				{
					"color": "#E2E8F0",
					"name": "Stroke",
					"slug": "stroke"
				}
			]
		},
		"custom": {
			"borderRadius": "0px",
			"buttonPadding": {
				"medium": "calc(1.215em + 2px) calc(1.5em + 2px)"
			},
			"spacing": {
				"large": "8rem",
				"medium": "4rem",
				"small": "max(1.25rem, 5vw)"
			},
			"typography": {
				"font-size": {
					"heading-1": "2.5rem",
					"heading-2": "2.125rem",
					"heading-3": "1.75rem",
					"heading-4": "1.5rem",
					"heading-5": "1.25rem",
					"heading-6": "1.125rem"
				},
				"letter-spacing": "2px",
				"line-height": {
					"medium": 1.399999999999999911182158029987476766109466552734375,
					"normal": 1.600000000000000088817841970012523233890533447265625,
					"small": 1.1999999999999999555910790149937383830547332763671875,
					"tiny": 1.149999999999999911182158029987476766109466552734375
				}
			}
		},
		"layout": {
			"contentSize": "720px",
			"wideSize": "1170px"
		},
		"spacing": {
			"units": [
				"%",
				"px",
				"em",
				"rem",
				"vh",
				"vw"
			]
		},
		"typography": {
			"defaultFontSizes": false,
			"fontFamilies": [
				{
					"fontFamily": "-apple-system,BlinkMacSystemFont,\"Segoe UI\",Roboto,Oxygen-Sans,Ubuntu,Cantarell,\"Helvetica Neue\",sans-serif",
					"name": "System Font",
					"slug": "system-font"
				},
				{
					"fontFace": [
						{
							"fontDisplay": "swap",
							"fontFamily": "Gilda Display",
							"fontStretch": "normal",
							"fontStyle": "normal",
							"fontWeight": "400",
							"src": [
								"file:./assets/fonts/gilda-display/GildaDisplay-Regular.woff"
							]
						}
					],
					"fontFamily": "\"Gilda Display\", serif",
					"name": "Gilda Display",
					"slug": "headings"
				},
				{
					"fontFace": [
						{
							"fontDisplay": "swap",
							"fontFamily": "Nunito Sans",
							"fontStretch": "normal",
							"fontStyle": "normal",
							"fontWeight": "400",
							"src": [
								"file:./assets/fonts/nunito-sans/NunitoSans-Regular.woff"
							]
						},
						{
							"fontDisplay": "swap",
							"fontFamily": "Nunito Sans",
							"fontStretch": "normal",
							"fontStyle": "italic",
							"fontWeight": "400",
							"src": [
								"file:./assets/fonts/nunito-sans/NunitoSans-Italic.woff"
							]
						},
						{
							"fontDisplay": "swap",
							"fontFamily": "Nunito Sans",
							"fontStretch": "normal",
							"fontStyle": "normal",
							"fontWeight": "600",
							"src": [
								"file:./assets/fonts/nunito-sans/NunitoSans-SemiBold.woff"
							]
						},
						{
							"fontDisplay": "swap",
							"fontFamily": "Nunito Sans",
							"fontStretch": "normal",
							"fontStyle": "normal",
							"fontWeight": "700",
							"src": [
								"file:./assets/fonts/nunito-sans/NunitoSans-Bold.woff"
							]
						}
					],
					"fontFamily": "\"Nunito Sans\", sans-serif",
					"name": "Nunito Sans",
					"slug": "base"
				},
				{
					"fontFace": [
						{
							"fontDisplay": "swap",
							"fontFamily": "Bestermind",
							"fontStretch": "normal",
							"fontStyle": "normal",
							"fontWeight": "400",
							"src": [
								"file:./assets/fonts/bestermind/BestermindRegular.woff"
							]
						}
					],
					"fontFamily": "\"Bestermind\", sans-serif",
					"name": "Bestermind",
					"slug": "alt"
				}
			],
			"fontSizes": [
				{
					"name": "Tiny",
					"size": "0.75rem",
					"slug": "tiny"
				},
				{
					"name": "Small",
					"size": "0.875rem",
					"slug": "small"
				},
				{
					"name": "Base",
					"size": "1.125rem",
					"slug": "base"
				},
				{
					"name": "Medium Small",
					"size": "1.125rem",
					"slug": "medium-small"
				},
				{
					"name": "Medium",
					"size": "1.5rem",
					"slug": "medium"
				},
				{
					"name": "Medium Large",
					"size": "clamp(1.5rem, 2.5vw, 2.25rem)",
					"slug": "medium-large"
				},
				{
					"name": "Large",
					"size": "clamp(2rem, 1.7573rem + 1.0356vw, 3rem)",
					"slug": "large"
				},
				{
					"name": "X-Large",
					"size": "clamp(2.5rem, 2.1966rem + 1.2945vw, 3.75rem)",
					"slug": "x-large"
				}
			]
		}
